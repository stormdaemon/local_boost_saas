# ============================================================
# ProspectPilot Local — variables d'environnement
# Copier vers .env en local ; configurer les mêmes sur Netlify.
# Aucune de ces valeurs ne doit être commitée.
# ============================================================

# --- Moteur d'analyse (côté serveur uniquement) ---
GEMINI_API_KEY=

# --- Base de données PostgreSQL (Supabase, pooler transactionnel 6543) ---
# Format : postgresql://postgres.<ref>:<MOT_DE_PASSE>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
# Pooler session (5432) — utilisé uniquement pour `prisma db push` / migrations
DIRECT_DATABASE_URL=

# --- Paiement PayPal (côté serveur uniquement) ---
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# "sandbox" ou "live"
PAYPAL_ENV=sandbox
# Identifiant du webhook PayPal (vérification de signature)
WEBHOOK_CLIENT_ID=
# Secret applicatif interne (chaîne aléatoire >= 32 caractères)
WEBHOOK_SECRET=

# --- Supabase (auth + emails de confirmation) ---
# L'URL et la clé "anon/publishable" sont publiques par conception.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : serveur uniquement, ne jamais exposer
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# URL publique du site déployé (utilisée pour SEO, sitemap, retours PayPal)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
